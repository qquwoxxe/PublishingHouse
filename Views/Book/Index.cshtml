@using PublishingHouse.Helpers
@model List<PublishingHouse.Models.Book>

@{
    ViewBag.Title = "Список книг";

    // ЧАСТЬ II: получение ID текущей книги из Session
    int? currentBookId = Session["CurrentBookId"] as int?;
    var currentBook = currentBookId.HasValue ? Model.FirstOrDefault(b => b.Id == currentBookId) : null;

    // ЧАСТЬ III: чтение значения из TempData для выбора метода
    bool useInternalMethod = TempData["UseInternalMethod"] != null && (bool)TempData["UseInternalMethod"];

    // Сохраняем TempData для следующего запроса
    TempData.Keep("UseInternalMethod");
}

<h2>Список книг</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (currentBook != null)
{
    <div class="alert alert-info">
        <strong>Текущая выбранная книга:</strong>
        ID: @currentBook.Id |
        Название: @currentBook.Title |
        Автор: @currentBook.Author
    </div>
}

<p>
    @Html.ActionLink("Добавить новую книгу", "Create", null, new { @class = "btn btn-success" })
</p>

@* ЧАСТЬ III: вызов вспомогательных методов в зависимости от TempData *@
@if (useInternalMethod)
{
    @* Вызов ВНУТРЕННЕГО метода *@
    var controller = (PublishingHouse.Controllers.BookController)ViewContext.Controller;
    @controller.InternalBookList(Model, "Список книг (внутренний метод)")
}
else
{
    @* Вызов ВНЕШНЕГО метода *@
    @Html.ExternalBookList(Model, "Список книг (внешний метод)")
}

@* ЧАСТЬ II: таблица с циклом for (вариант Б) *@
@if (Model.Count == 0)
{
    <p>Нет книг. Добавьте первую!</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Автор</th>
                <th>Жанр</th>
                <th>Год</th>
                <th>Страниц</th>
                <th>ISBN</th>
                <th>Цена</th>
                <th>Действия</th>
                <th>Выбрать</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var book = Model[i];
                var isCurrent = currentBookId.HasValue && currentBookId.Value == book.Id;

                <tr class="@(isCurrent ? "table-primary" : "")">
                    <td>@book.Id</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Genre</td>
                    <td>@book.Year</td>
                    <td>@book.PageCount</td>
                    <td>@book.ISBN</td>
                    <td>@book.Price.ToString("C")</td>
                    <td>
                        @Html.ActionLink("Просмотр", "Details", new { id = book.Id }, new { @class = "btn btn-sm btn-info" })
                        @Html.ActionLink("Редактировать", "Edit", new { id = book.Id }, new { @class = "btn btn-sm btn-warning" })
                    </td>
                    <td>
                        @if (!isCurrent)
                        {
                            @Html.ActionLink("Выбрать", "Select", new { id = book.Id }, new { @class = "btn btn-sm btn-primary" })
                        }
                        else
                        {
                            <span class="badge badge-success">Текущая</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}